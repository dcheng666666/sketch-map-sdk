{
  "name": "sketch-map-sdk",
  "version": "0.1.0",
  "description": "Hand-drawn travel-route map renderer (support browser + Node).",
  "keywords": [
    "map",
    "sketch",
    "travel",
    "route",
    "svg",
    "png"
  ],
  "license": "MIT",
  "author": "dacheng",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dcheng666666/sketch-map-sdk.git"
  },
  "homepage": "https://github.com/dcheng666666/sketch-map-sdk#readme",
  "bugs": {
    "url": "https://github.com/dcheng666666/sketch-map-sdk/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.23.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser.d.ts",
        "import": "./dist/browser.js"
      },
      "node": {
        "types": "./dist/headless.d.ts",
        "import": "./dist/headless.js"
      },
      "default": {
        "types": "./dist/headless.d.ts",
        "import": "./dist/headless.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-data.mjs",
    "build:cities": "node ./scripts/build-cities.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:publish": "publint",
    "lint:types": "attw --pack . --ignore-rules cjs-resolves-to-esm",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "pnpm audit --audit-level=high",
    "secret:scan": "node ./scripts/secret-scan-staged.mjs",
    "pack:check": "npm pack --dry-run",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,yml,yaml,json,toml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@turf/bbox": "^7.3.5",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "jsdom": "^26.1.0",
    "roughjs": "^4.6.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@secretlint/secretlint-rule-preset-recommend": "^9.3.1",
    "@turf/simplify": "^7.3.5",
    "@types/geojson": "^7946.0.16",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.12.3",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import-x": "^4.16.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "secretlint": "^9.3.1",
    "size-limit": "^12.1.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.60.0"
  }
}
